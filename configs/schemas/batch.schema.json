{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprite-builder.local/schemas/batch.schema.json",
  "title": "Sprite Builder BatchSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch", "characters"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "minLength": 1}
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "jobs"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "jobs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
